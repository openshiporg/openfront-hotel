  updatedAt   DateTime @default(now()) @updatedAt

  @@index([guestId])
  @@index([bookingId])
  @@index([createdById])
}

model RatePlan {
  id                  String    @id @default(cuid())
  name                String    @unique @default("")
  description         String    @default("")
