datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                                 String                @id @default(cuid())
  name                               String                @default("")
  email                              String                @unique @default("")
  password                           String
  role                               Role?                 @relation("User_role", fields: [roleId], references: [id])
  roleId                             String?               @map("role")
  phone                              String                @default("")
  isActive                           Boolean               @default(true)
  onboardingStatus                   String?               @default("not_started")
  bookings                           Booking[]             @relation("Booking_guest")
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @default(now()) @updatedAt
  passwordResetToken                 String?
  passwordResetIssuedAt              DateTime?
  passwordResetRedeemedAt            DateTime?
  from_HousekeepingTask_assignedTo   HousekeepingTask[]    @relation("HousekeepingTask_assignedTo")
  from_BookingPayment_processedBy    BookingPayment[]      @relation("BookingPayment_processedBy")
  from_ReservationLineItem_postedBy  ReservationLineItem[] @relation("ReservationLineItem_postedBy")
  from_Guest_userAccount             Guest[]               @relation("Guest_userAccount")
  from_GuestDocument_verifiedBy      GuestDocument[]       @relation("GuestDocument_verifiedBy")
  from_LoyaltyTransaction_createdBy  LoyaltyTransaction[]  @relation("LoyaltyTransaction_createdBy")
  from_MaintenanceRequest_reportedBy MaintenanceRequest[]  @relation("MaintenanceRequest_reportedBy")
  from_MaintenanceRequest_assignedTo MaintenanceRequest[]  @relation("MaintenanceRequest_assignedTo")
  from_ChannelSyncEvent_createdBy    ChannelSyncEvent[]    @relation("ChannelSyncEvent_createdBy")

  @@index([roleId])
}

model Role {
  id                    String   @id @default(cuid())
  name                  String   @default("")
  canAccessDashboard    Boolean  @default(false)
  canManageRooms        Boolean  @default(false)
  canManageBookings     Boolean  @default(false)
  canManageHousekeeping Boolean  @default(false)
  canManageGuests       Boolean  @default(false)
  canManagePayments     Boolean  @default(false)
  canSeeOtherPeople     Boolean  @default(false)
  canEditOtherPeople    Boolean  @default(false)
  canManagePeople       Boolean  @default(false)
  canManageRoles        Boolean  @default(false)
  canManageOnboarding   Boolean  @default(false)
  assignedTo            User[]   @relation("User_role")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
}

model RoomType {
  id                               String               @id @default(cuid())
  name                             String               @unique @default("")
  description                      Json                 @default("[{\"type\":\"paragraph\",\"children\":[{\"text\":\"\"}]}]")
  baseRate                         Float
  maxOccupancy                     Int                  @default(2)
  bedConfiguration                 String?
  amenities                        Json                 @default("[]")
  squareFeet                       Int?
  rooms                            Room[]               @relation("Room_roomType")
  roomAssignments                  RoomAssignment[]     @relation("RoomAssignment_roomType")
  ratePlans                        RatePlan[]           @relation("RatePlan_roomType")
  createdAt                        DateTime             @default(now())
  updatedAt                        DateTime             @default(now()) @updatedAt
  from_RoomInventory_roomType      RoomInventory[]      @relation("RoomInventory_roomType")
  from_SeasonalRate_roomType       SeasonalRate[]       @relation("SeasonalRate_roomType")
  from_ChannelReservation_roomType ChannelReservation[] @relation("ChannelReservation_roomType")
}

model Room {
  id                           String               @id @default(cuid())
  roomNumber                   String               @unique @default("")
  roomType                     RoomType?            @relation("Room_roomType", fields: [roomTypeId], references: [id])
  roomTypeId                   String?              @map("roomType")
  floor                        Int?
  status                       String?              @default("vacant")
  lastCleaned                  DateTime?
  notes                        String               @default("")
  housekeepingTasks            HousekeepingTask[]   @relation("HousekeepingTask_room")
  roomAssignments              RoomAssignment[]     @relation("RoomAssignment_room")
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @default(now()) @updatedAt
  from_MaintenanceRequest_room MaintenanceRequest[] @relation("MaintenanceRequest_room")

  @@index([roomTypeId])
}

model RoomInventory {
  id           String    @id @default(cuid())
  date         DateTime
  roomType     RoomType? @relation("RoomInventory_roomType", fields: [roomTypeId], references: [id])
  roomTypeId   String?   @map("roomType")
  totalRooms   Int       @default(0)
  bookedRooms  Int       @default(0)
  blockedRooms Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([date])
  @@index([roomTypeId])
}

model HousekeepingTask {
  id           String    @id @default(cuid())
  room         Room?     @relation("HousekeepingTask_room", fields: [roomId], references: [id])
  roomId       String?   @map("room")
  taskType     String
  assignedTo   User?     @relation("HousekeepingTask_assignedTo", fields: [assignedToId], references: [id])
  assignedToId String?   @map("assignedTo")
  priority     Int?      @default(2)
  status       String?   @default("pending")
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([roomId])
  @@index([assignedToId])
}

model RoomAssignment {
  id              String    @id @default(cuid())
  booking         Booking?  @relation("RoomAssignment_booking", fields: [bookingId], references: [id])
  bookingId       String?   @map("booking")
  room            Room?     @relation("RoomAssignment_room", fields: [roomId], references: [id])
  roomId          String?   @map("room")
  roomType        RoomType? @relation("RoomAssignment_roomType", fields: [roomTypeId], references: [id])
  roomTypeId      String?   @map("roomType")
  ratePerNight    Float?
  guestName       String    @default("")
  specialRequests String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([bookingId])
  @@index([roomId])
  @@index([roomTypeId])
}

model Booking {
  id                                   String                  @id @default(cuid())
  confirmationNumber                   String                  @unique @default("")
  guestName                            String                  @default("")
  guestEmail                           String                  @default("")
  guestPhone                           String                  @default("")
  checkInDate                          DateTime
  checkOutDate                         DateTime
  numberOfGuests                       Int                     @default(1)
  numberOfAdults                       Int?                    @default(1)
  numberOfChildren                     Int?                    @default(0)
  roomRate                             Float?
  taxAmount                            Float?                  @default(0)
  feesAmount                           Float?                  @default(0)
  totalAmount                          Float?
  depositAmount                        Float?                  @default(0)
  balanceDue                           Float?
  status                               String?                 @default("pending")
  paymentStatus                        String?                 @default("unpaid")
  source                               String?                 @default("direct")
  specialRequests                      String                  @default("")
  internalNotes                        String                  @default("")
  roomAssignments                      RoomAssignment[]        @relation("RoomAssignment_booking")
  guestProfile                         Guest?                  @relation("Booking_guestProfile", fields: [guestProfileId], references: [id])
  guestProfileId                       String?                 @map("guestProfile")
  guest                                User?                   @relation("Booking_guest", fields: [guestId], references: [id])
  guestId                              String?                 @map("guest")
  payments                             BookingPayment[]        @relation("BookingPayment_booking")
  paymentSessions                      BookingPaymentSession[] @relation("BookingPaymentSession_booking")
  confirmedAt                          DateTime?
  checkedInAt                          DateTime?
  checkedOutAt                         DateTime?
  cancelledAt                          DateTime?
  createdAt                            DateTime                @default(now())
  updatedAt                            DateTime                @default(now()) @updatedAt
  from_ReservationLineItem_reservation ReservationLineItem[]   @relation("ReservationLineItem_reservation")
  from_LoyaltyTransaction_booking      LoyaltyTransaction[]    @relation("LoyaltyTransaction_booking")
  from_ChannelReservation_reservation  ChannelReservation[]    @relation("ChannelReservation_reservation")

  @@index([guestProfileId])
  @@index([guestId])
}

model BookingPayment {
  id                    String                 @id @default(cuid())
  paymentReference      String                 @unique @default("")
  paymentType           String                 @default("full_payment")
  amount                Float
  currency              String                 @default("USD")
  paymentMethod         String                 @default("credit_card")
  status                String?                @default("pending")
  providerPaymentId     String                 @default("")
  providerCaptureId     String                 @default("")
  providerRefundId      String                 @default("")
  providerData          Json?                  @default("{}")
  stripePaymentIntentId String                 @default("")
  stripeChargeId        String                 @default("")
  stripeRefundId        String                 @default("")
  cardBrand             String                 @default("")
  cardLast4             String                 @default("")
  cardExpMonth          String                 @default("")
  cardExpYear           String                 @default("")
  receiptEmail          String                 @default("")
  receiptUrl            String                 @default("")
  description           String                 @default("")
  internalNotes         String                 @default("")
  failureReason         String                 @default("")
  booking               Booking?               @relation("BookingPayment_booking", fields: [bookingId], references: [id])
  bookingId             String?                @map("booking")
  paymentProvider       PaymentProvider?       @relation("BookingPayment_paymentProvider", fields: [paymentProviderId], references: [id])
  paymentProviderId     String?                @map("paymentProvider")
  paymentSession        BookingPaymentSession? @relation("BookingPayment_paymentSession", fields: [paymentSessionId], references: [id])
  paymentSessionId      String?                @map("paymentSession")
  processedBy           User?                  @relation("BookingPayment_processedBy", fields: [processedById], references: [id])
  processedById         String?                @map("processedBy")
  processedAt           DateTime?
  refundedAt            DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt

  @@index([bookingId])
  @@index([paymentProviderId])
  @@index([paymentSessionId])
  @@index([processedById])
}

model BookingPaymentSession {
  id                                 String           @id @default(cuid())
  isSelected                         Boolean          @default(false)
  isInitiated                        Boolean          @default(false)
  amount                             Int
  data                               Json?            @default("{}")
  idempotencyKey                     String           @default("")
  booking                            Booking?         @relation("BookingPaymentSession_booking", fields: [bookingId], references: [id])
  bookingId                          String?          @map("booking")
  paymentProvider                    PaymentProvider? @relation("BookingPaymentSession_paymentProvider", fields: [paymentProviderId], references: [id])
  paymentProviderId                  String?          @map("paymentProvider")
  paymentAuthorizedAt                DateTime?
  createdAt                          DateTime         @default(now())
  updatedAt                          DateTime         @default(now()) @updatedAt
  from_BookingPayment_paymentSession BookingPayment[] @relation("BookingPayment_paymentSession")

  @@index([idempotencyKey])
  @@index([bookingId])
  @@index([paymentProviderId])
}

model PaymentProvider {
  id                          String                  @id @default(cuid())
  name                        String                  @default("")
  code                        String                  @unique @default("")
  isInstalled                 Boolean                 @default(true)
  credentials                 Json?                   @default("{}")
