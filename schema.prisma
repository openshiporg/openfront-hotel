  roomTypeId          String?   @map("roomType")
  baseRate            Float
  seasonalAdjustments Json?     @default("{\"peak\":1.25,\"high\":1.15,\"regular\":1,\"low\":0.85}")
  minimumStay         Int?      @default(1)
  maximumStay         Int?
  advanceBookingMin   Int?      @default(0)
  advanceBookingMax   Int?
  cancellationPolicy  String?   @default("moderate")
  mealPlan            String?   @default("room_only")
  validFrom           DateTime?
  validTo             DateTime?
  applicableDays      Json?     @default("{\"monday\":true,\"tuesday\":true,\"wednesday\":true,\"thursday\":true,\"friday\":true,\"saturday\":true,\"sunday\":true}")
  status              String?   @default("draft")
  isPublic            Boolean   @default(true)
  isPromotional       Boolean   @default(false)
  promoCode           String    @default("")
  priority            Int?      @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt

  @@index([roomTypeId])
}

model SeasonalRate {
  id              String    @id @default(cuid())
  name            String    @default("")
